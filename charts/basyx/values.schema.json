{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "serviceRuntimeOverrides": {
      "type": "object",
      "properties": {
        "general": { "$ref": "#/properties/general" },
        "server": { "$ref": "#/properties/server" },
        "history": { "$ref": "#/properties/history" },
        "eventing": { "$ref": "#/properties/eventing" },
        "abac": {
          "type": "object",
          "properties": {
            "policyFileImport": { "type": "string", "enum": ["", "always", "if_missing", "never"] },
            "policyScope": {
              "type": "string",
              "maxLength": 255,
              "pattern": "^$|^[A-Za-z0-9_.:-]+$"
            },
            "managementApi": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            }
          }
        },
        "environment": { "type": "object" }
      }
    }
  },
  "required": [
    "instanceName",
    "host",
    "paths",
    "environment",
    "keycloak",
    "database"
  ],
  "properties": {
    "instanceName": {
      "type": "string",
      "minLength": 1
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "paths": {
      "type": "object",
      "required": [
        "aasDiscovery",
        "aasRegistry",
        "aasRepository",
        "aasEnvironment",
        "dppApi",
        "submodelRegistry",
        "submodelRepository",
        "cdRepository",
        "companyLookup",
        "aasWebUi",
        "aasWebUiBasePath",
        "keycloak",
        "digitalTwinRegistry"
      ],
      "properties": {
        "aasDiscovery": { "type": "string", "minLength": 1, "pattern": "^/" },
        "aasRegistry": { "type": "string", "minLength": 1, "pattern": "^/" },
        "aasRepository": { "type": "string", "minLength": 1, "pattern": "^/" },
        "aasEnvironment": { "type": "string", "minLength": 1, "pattern": "^/" },
        "dppApi": { "type": "string", "minLength": 1, "pattern": "^/" },
        "submodelRegistry": { "type": "string", "minLength": 1, "pattern": "^/" },
        "submodelRepository": { "type": "string", "minLength": 1, "pattern": "^/" },
        "cdRepository": { "type": "string", "minLength": 1, "pattern": "^/" },
        "companyLookup": { "type": "string", "minLength": 1, "pattern": "^/" },
        "aasWebUi": { "type": "string", "minLength": 1, "pattern": "^/" },
        "aasWebUiBasePath": { "type": "string", "minLength": 1, "pattern": "^/" },
        "keycloak": { "type": "string", "minLength": 1, "pattern": "^/" },
        "digitalTwinRegistry": { "type": "string", "minLength": 1, "pattern": "^/" }
      }
    },
    "internal": {
      "type": "object",
      "properties": {
        "CACertificates": {
          "type": "object",
          "properties": {
            "trustStore": {
              "type": "object",
              "properties": {
                "useDefaultCAs": { "type": "boolean" },
                "mountPath": { "type": "string", "minLength": 1, "pattern": "^/" },
                "chartFileDirectory": { "type": "string" },
                "additionalCACertificates": { "type": "string" },
                "extraSecrets": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "extraConfigMaps": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "required": ["common"],
      "properties": {
        "common": {
          "type": "object",
          "required": ["OIDC_AUDIENCE"],
          "properties": {
            "OIDC_AUDIENCE": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "keycloak": {
      "type": "object",
      "required": [
        "realm",
        "webUiClientId",
        "service",
        "secrets",
        "initialization"
      ],
      "properties": {
        "realm": {
          "type": "string",
          "minLength": 1
        },
        "webUiClientId": {
          "type": "string",
          "minLength": 1
        },
        "initJob": {
          "type": "object",
          "properties": {
            "image": {
              "type": "object",
              "required": ["repository", "pullPolicy"],
              "properties": {
                "repository": { "type": "string", "minLength": 1 },
                "pullPolicy": { "type": "string", "minLength": 1 },
                "tag": { "type": ["string", "number"] },
                "digest": { "type": "string" }
              }
            }
          }
        },
        "tests": {
          "type": "object",
          "properties": {
            "realmCheck": {
              "type": "object",
              "properties": {
                "image": {
                  "type": "object",
                  "required": ["repository", "pullPolicy"],
                  "properties": {
                    "repository": { "type": "string", "minLength": 1 },
                    "pullPolicy": { "type": "string", "minLength": 1 },
                    "tag": { "type": ["string", "number"] },
                    "digest": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "service": {
          "type": "object",
          "required": ["port"],
          "properties": {
            "port": {
              "oneOf": [
                { "type": "integer", "minimum": 1 },
                { "type": "string", "minLength": 1 }
              ]
            }
          }
        },
        "managementPort": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "secrets": {
          "type": "object",
          "required": ["name", "admin", "client"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "admin": {
              "type": "object",
              "required": ["username", "password"],
              "properties": {
                "username": { "type": "string", "minLength": 1 },
                "password": { "type": "string", "minLength": 1 }
              }
            },
            "client": {
              "type": "object",
              "required": ["name", "clientPassword"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "clientPassword": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "initialization": {
          "type": "object",
          "required": ["roles", "clients", "users"],
          "properties": {
            "userProfile": { "type": "object" },
            "roles": { "type": "array" },
            "clients": { "type": "array" },
            "users": { "type": "array" }
          }
        }
      }
    },
    "tls": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "hosts": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "general": {
      "type": "object",
      "properties": {
        "enableImplicitCasts": { "type": "boolean" },
        "enableDescriptorDebug": { "type": "boolean" },
        "discoveryIntegration": { "type": "boolean" },
        "enableCustomMiddlewareHeaderInjection": { "type": "boolean" },
        "supportsSingularSupplementalSemanticId": { "type": "boolean" },
        "aasRegistryIntegration": { "type": "boolean" },
        "submodelRegistryIntegration": { "type": "boolean" },
        "externalUrl": { "type": "string" },
        "trustProxyHeaders": { "type": "boolean" },
        "trustedProxyCIDRs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "uploadMaxSizeBytes": { "type": "integer", "minimum": 0 },
        "bulkBatchLimit": { "type": "integer", "minimum": 1 },
        "aasPreconfigPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "server": {
      "type": "object",
      "properties": {
        "readHeaderTimeoutSeconds": { "type": "integer", "minimum": 1 },
        "readTimeoutSeconds": { "type": "integer", "minimum": 1 },
        "writeTimeoutSeconds": { "type": "integer", "minimum": 1 },
        "idleTimeoutSeconds": { "type": "integer", "minimum": 1 },
        "shutdownTimeoutSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "history": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["off", "api", "audit"] },
        "retentionDays": { "type": "integer", "minimum": 0 },
        "fullSnapshotInterval": { "type": "integer", "minimum": 1 },
        "immutability": { "type": "string", "enum": ["none", "postgres_guarded", "external_anchor"] },
        "auditIdentityMode": { "type": "string", "enum": ["none", "minimal", "extended"] },
        "evidence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "provider": { "type": "string" },
            "bucket": { "type": "string" },
            "prefix": { "type": "string" },
            "region": { "type": "string" },
            "endpoint": { "type": "string" },
            "accessKeyId": { "type": "string" },
            "secretAccessKey": { "type": "string" },
            "pathStyle": { "type": "boolean" },
            "retentionMode": { "type": "string" },
            "retentionDays": { "type": "integer", "minimum": 0 },
            "writeTimeoutSeconds": { "type": "integer", "minimum": 1 },
            "signing": {
              "type": "object",
              "properties": {
                "privateKeyPath": { "type": "string" },
                "publicKeyPath": { "type": "string" },
                "required": { "type": "boolean" }
              }
            }
          }
        },
        "integrityAnchor": {
          "type": "object",
          "properties": {
            "provider": { "type": "string" }
          }
        }
      }
    },
    "eventing": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "format": { "type": "string" },
        "sinks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "outboxEnabled": { "type": "boolean" },
        "topicPrefix": { "type": "string" }
      }
    },
    "proxy": {
      "type": "object",
      "properties": {
        "http": { "type": "string" },
        "https": { "type": "string" },
        "noProxy": { "type": "string" }
      }
    },
    "configurationService": {
      "type": "object",
      "required": ["enabled", "image", "hook", "backoffLimit", "restartPolicy"],
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "required": ["repository", "pullPolicy"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "pullPolicy": { "type": "string", "minLength": 1 },
            "tag": { "type": ["string", "number"] },
            "digest": { "type": "string" }
          }
        },
        "imagePullSecrets": { "type": "array" },
        "command": { "type": "array" },
        "args": { "type": "array" },
        "waitForDatabase": {
          "type": "object",
          "required": ["enabled", "image", "intervalSeconds", "timeoutSeconds"],
          "properties": {
            "enabled": { "type": "boolean" },
            "image": {
              "type": "object",
              "required": ["repository", "pullPolicy"],
              "properties": {
                "repository": { "type": "string", "minLength": 1 },
                "pullPolicy": { "type": "string", "minLength": 1 },
                "tag": { "type": ["string", "number"] },
                "digest": { "type": "string" }
              }
            },
            "intervalSeconds": { "type": "integer", "minimum": 1 },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "resources": { "type": "object" }
          }
        },
        "hook": {
          "type": "object",
          "required": ["enabled", "events", "weight", "deletePolicy"],
          "properties": {
            "enabled": { "type": "boolean" },
            "events": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "weight": { "type": "string" },
            "deletePolicy": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "annotations": { "type": "object" }
          }
        },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "restartPolicy": {
          "type": "string",
          "enum": ["Never", "OnFailure"]
        },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" }
      }
    },
    "abac": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "policyFileImport": { "type": "string", "enum": ["", "always", "if_missing", "never"] },
        "policyScope": {
          "type": "string",
          "maxLength": 255,
          "pattern": "^$|^[A-Za-z0-9_.:-]+$"
        },
        "managementApi": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "mountPath": { "type": "string" },
        "accessRulesFileName": { "type": "string" },
        "trustListFileName": { "type": "string" },
        "accessRules": { "type": "string" },
        "trustList": { "type": "string" }
      }
    },
    "aasDiscovery": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "aasRegistry": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "aasRepository": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "aasEnvironment": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "dppApi": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "submodelRegistry": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "submodelRepository": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "cdRepository": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "companyLookup": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "digitalTwinRegistry": { "$ref": "#/definitions/serviceRuntimeOverrides" },
    "database": {
      "type": "object",
      "required": ["clusterName", "type", "instances", "storage"],
      "properties": {
        "clusterName": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["postgres", "managed", "cnpg", "external"]
        },
        "existingSecret": {
          "type": "string"
        },
        "external": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "port": { "type": ["string", "number"] },
            "dbname": { "type": "string" },
            "user": { "type": "string" },
            "password": { "type": "string" }
          }
        },
        "instances": {
          "type": "integer",
          "minimum": 1
        },
        "storage": {
          "type": "object",
          "required": ["size"],
          "properties": {
            "size": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "const": "external" }
            }
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "existingSecret": { "minLength": 1 }
                },
                "required": ["existingSecret"]
              },
              {
                "properties": {
                  "external": {
                    "type": "object",
                    "required": ["host", "port", "dbname", "user", "password"],
                    "properties": {
                      "host": { "minLength": 1 },
                      "port": {
                        "oneOf": [
                          { "type": "integer", "minimum": 1 },
                          { "type": "string", "minLength": 1 }
                        ]
                      },
                      "dbname": { "minLength": 1 },
                      "user": { "minLength": 1 },
                      "password": { "minLength": 1 }
                    }
                  }
                },
                "required": ["external"]
              }
            ]
          }
        }
      ]
    }
  }
}
